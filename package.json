{
  "name": "business-charts",
  "description": "Powerful visualizations powered by Apache ECharts",
  "version": "7.2.5",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "levitate": "npx @grafana/levitate@latest is-compatible --path src/module.ts --target @grafana/data,@grafana/runtime,@grafana/ui",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "markdownlint": "markdownlint-cli2 AGENTS.md CHANGELOG.md README.md",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "start": "docker compose --profile production up",
    "start:dev": "docker compose --profile dev up",
    "stop": "docker compose down",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4 --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:dev": "npx playwright test --ui",
    "test:e2e:docker": "docker compose --profile playwright up --force-recreate --abort-on-container-exit --exit-code-from playwright",
    "test:e2e:update": "docker compose build grafana && docker compose run --rm playwright npx playwright test --update-snapshots",
    "typecheck": "tsc --noEmit",
    "upgrade": "npm upgrade --save"
  },
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "devDependencies": {
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/plugin-e2e": "^3.5.1",
    "@grafana/tsconfig": "^2.0.1",
    "@playwright/test": "^1.59.1",
    "@stylistic/eslint-plugin": "^5.5.0",
    "@swc/core": "^1.15.18",
    "@swc/helpers": "^0.5.19",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.0.0",
    "@types/semver": "^7.7.1",
    "@types/uuid": "^10.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "cspell": "^10.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-jsdoc": "^62.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-webpack-plugin": "^5.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^11.0.3",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.1",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "^1.97.1",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3",
    "util": "^0.12.5",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.0",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@grafana/data": "^12.4.1",
    "@grafana/runtime": "^12.4.1",
    "@grafana/scenes": "^6.57.2",
    "@grafana/ui": "^12.4.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@types/googlemaps": "^3.43.3",
    "echarts": "^5.6.0",
    "echarts-extension-amap": "^1.12.0",
    "echarts-extension-gmap": "^1.7.0",
    "echarts-gl": "^2.0.9",
    "echarts-liquidfill": "^3.1.0",
    "echarts-stat": "^1.2.0",
    "echarts-wordcloud": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semver": "^7.7.4",
    "tslib": "^2.8.0",
    "uuid": "^13.0.0"
  }
}
